<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="煦濬③⑴源宒 (cate_method)">
            <AutoCompleteTextView android:id="@+id/actvCateMethod"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="text" android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="煦濬URL (cate_url) 瞰: /index.php/vod/show/id/{tid}/page/{pg}.html">
            <EditText android:id="@+id/etCateUrl" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="菴1珜黃蕾URL (cate_page_1)">
            <EditText android:id="@+id/etCatePage1" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="POST极 (cate_body)">
            <EditText android:id="@+id/etCateBody" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="12dp" android:background="#E0E0E0" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="蹈桶砐饜离" android:textStyle="bold" android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="蹈桶CSS恁寁ん (cate_item) 瞰: .myui-vodlist__item a">
            <EditText android:id="@+id/etCateItem" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="ID趼僇 (cate_id) 瞰: a@href">
            <EditText android:id="@+id/etCateId" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="靡備趼僇 (cate_name) 瞰: a@title">
            <EditText android:id="@+id/etCateName" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="芞え趼僇 (cate_pic) 瞰: a@data-original">
            <EditText android:id="@+id/etCatePic" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="掘蛁趼僇 (cate_remarks)">
            <EditText android:id="@+id/etCateRemarks" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="JSON蹈桶繚噤 (cate_list_path) 瞰: list 麼 data.list">
            <EditText android:id="@+id/etCateListPath" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="砆①珜URL耀啣 (detail_url)">
            <EditText android:id="@+id/etDetailUrl" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="12dp" android:background="#E0E0E0" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="煦濬蹈桶 (classes)" android:textStyle="bold" android:layout_marginTop="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClasses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="100dp"
            android:layout_marginTop="4dp"
            android:background="#F5F5F5" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddClass"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|bottom"
            android:layout_margin="16dp"
            android:src="@android:drawable/ic_menu_add" />

    </LinearLayout>
</ScrollView>
