<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="详情方式 (detail_method)">
            <AutoCompleteTextView android:id="@+id/actvDetailMethod"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="text" android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="详情POST体 (detail_body)">
            <EditText android:id="@+id/etDetailBody" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="8dp" android:background="#E0E0E0" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="字段提取规则 (支持CSS或KaiGeEngine规则)"
            android:textStyle="bold" android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="标题 (dt_name) 例: h1@text 或 .title@text">
            <EditText android:id="@+id/etDtName" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="封面 (dt_pic) 例: .poster@data-original">
            <EditText android:id="@+id/etDtPic" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="备注 (dt_remarks)">
            <EditText android:id="@+id/etDtRemarks" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="演员 (dt_actor)">
            <EditText android:id="@+id/etDtActor" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="导演 (dt_director)">
            <EditText android:id="@+id/etDtDirector" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="简介 (dt_content)">
            <EditText android:id="@+id/etDtContent" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="8dp" android:background="#E0E0E0" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="播放列表配置" android:textStyle="bold" android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="线路选择器 (dt_from) 例: li[h3]">
            <EditText android:id="@+id/etDtFrom" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="列表选择器 (dt_list) 例: ul.myui-content__list">
            <EditText android:id="@+id/etDtList" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
