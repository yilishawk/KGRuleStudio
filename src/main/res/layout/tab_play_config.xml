<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="?? 댔역 Steps 긍서포（꺄렴썩驕꼍朧）"
            android:textSize="16sp"
            android:padding="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="12dp" android:background="#E0E0E0" />

        <CheckBox android:id="@+id/cbDanmaku"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="폘痰뎐캥 (danmaku)"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="땡檄jx토零URL (play.jx)">
            <EditText android:id="@+id/etPlayJx" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx窟쨌튈토 (play_jx_list)">
            <EditText android:id="@+id/etPlayJxList" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx깃痙품留 (play_jx_title)">
            <EditText android:id="@+id/etPlayJxTitle" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx썩驕품留 (play_jx_parse)">
            <EditText android:id="@+id/etPlayJxParse" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
