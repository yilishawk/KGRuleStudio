<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ 打开 Steps 编辑器（播放解析步骤）"
            android:textSize="16sp"
            android:padding="16dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:layout_marginTop="12dp" android:background="#E0E0E0" />

        <CheckBox android:id="@+id/cbDanmaku"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="启用弹幕 (danmaku)"
            android:layout_marginTop="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="解析接口jx地址 (play.jx)">
            <EditText android:id="@+id/etPlayJx" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx解析白名单 (play_jx_list)">
            <EditText android:id="@+id/etPlayJxList" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx匹配标题关键词 (play_jx_title)">
            <EditText android:id="@+id/etPlayJxTitle" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:hint="jx匹配解析关键词 (play_jx_parse)">
            <EditText android:id="@+id/etPlayJxParse" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>
</ScrollView>
